# Steam Web API key — get one free at https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# Your SteamID64 (a 17-digit number) — find it at https://steamid.io
STEAM_ID=

# RAWG API key — free at https://rawg.io/apidocs
RAWG_API_KEY=

# Server port (default 3001)
PORT=3001

# Set to 1 to seed the database with sample games (no API keys needed)
DEMO=
